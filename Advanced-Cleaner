    if (Test-Path -LiteralPath $Root) {
        $keys = Get-ChildItem -Path $Root -Recurse -ErrorAction SilentlyContinue
        foreach ($key in $keys) {
            $keyName = $key.PSChildName
            if (Test-MatchesTarget $keyName) {
                $RegistryItems.Add([pscustomobject]@{ Type = "KEY"; Name = $keyName; Path = $key.PSPath })
            }

            try {
                foreach ($valueName in @($key.GetValueNames())) {
                    $matchesValueName = Test-MatchesTarget -Text $valueName
                    $matchesValueData = $false

                    $valueData = $null
                    try {
                        $valueData = $key.GetValue($valueName)
                    }
                    catch {
                    }

                    if ($valueData -is [string]) {
                        $trimmedData = $valueData.Trim('"')
                        $dataName = [System.IO.Path]::GetFileName($trimmedData)
                        if (-not [string]::IsNullOrWhiteSpace($dataName)) {
                            $matchesValueData = Test-MatchesTarget -Text $dataName
                        }
                    }

                    if ($matchesValueName -or $matchesValueData) {
                        $RegistryItems.Add([pscustomobject]@{ Type = "VALUE"; Name = $valueName; Path = $key.PSPath; ValueData = $valueData })
                    }
                }
            }
            catch {
            }
        }
    }
}

