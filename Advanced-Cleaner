        $item = $RegistryItems[$i]
        try {
            if ($item.Type -eq "KEY") {
                $confirmName = Split-Path $item.Path -Leaf
                if (-not (Test-MatchesTarget $confirmName)) {
                    throw "Registry key name verification failed"
                }
                Remove-Item -LiteralPath $item.Path -Recurse -Force -ErrorAction Stop
            }
            else {
                $valueMatches = Test-MatchesTarget $item.Name
                if (-not $valueMatches -and $item.PSObject.Properties.Match('ValueData').Count -gt 0 -and $null -ne $item.ValueData) {
                    $valueMatches = Test-TargetReference -Text ([string]$item.ValueData)
                }

                if (-not $valueMatches) {
                    throw "Registry value verification failed"
                }
                Remove-ItemProperty -Path $item.Path -Name $item.Name -ErrorAction Stop
            }

            Add-DeletedItem -Kind "REGISTRY" -Name $item.Name -Path $item.Path -Timestamp ([datetime]::MinValue)
