function Add-DeletedItem {
    param(
        [Parameter(Mandatory)]
        [string]$Kind,
        [Parameter(Mandatory)]
        [string]$Name,
        [Parameter(Mandatory)]
        [string]$Path,
        [datetime]$Timestamp = [datetime]::MinValue,
        [string]$Reason = $null
    )

    $script:DeletedItems.Add([pscustomobject]@{
        Kind = $Kind
        Name = $Name
        Path = $Path
        Timestamp = $Timestamp
        Reason = $Reason
    })
}

function Add-FailedItem {
    param(
        [Parameter(Mandatory)]
        [string]$Kind,
        [Parameter(Mandatory)]
        [string]$Name,
        [Parameter(Mandatory)]
        [string]$Path,
        [string]$Reason = $null
    )

    $script:FailedItems.Add([pscustomobject]@{
        Kind = $Kind
        Name = $Name
        Path = $Path
        Timestamp = (Get-Date)
        Reason = $Reason
    })
}

# UTILITY FUNCTIONS
function Test-MatchesTarget {
    param(
        [Parameter(Mandatory)]
        [string]$Text
    )

    if ($null -eq $TargetNames) {
        throw "TargetNames has not been initialized."
    }

    if ([string]::IsNullOrWhiteSpace($Text)) {
        return $false
    }

    return $TargetNames.Contains($Text)
}

function Test-IsProtectedPath {
    param([string]$Path)

    foreach ($protected in $script:ProtectedPaths) {
        if ($Path -and $Path.StartsWith($protected, [System.StringComparison]::OrdinalIgnoreCase)) {
            return $true
        }
    }

    return $false
}

function Get-TimeStatus {
    param(
        [int]$Current,
        [int]$Total,
        [datetime]$StartTime
    )

    $elapsed = (Get-Date) - $StartTime
    $elapsedText = $elapsed.ToString('hh\:mm\:ss')

    if ($Current -lt 5 -or $Total -le 0) {
        return "Elapsed: $elapsedText | ETA: Calculating..."
    }

    $averageSeconds = $elapsed.TotalSeconds / $Current
    $remainingSeconds = $averageSeconds * ($Total - $Current)
    $remaining = [timespan]::FromSeconds($remainingSeconds)

    return "Elapsed: $elapsedText | ETA: $($remaining.ToString('hh\:mm\:ss'))"
}

function Get-Speed {
    param(
        [int]$Current,
        [datetime]$StartTime
    )

    if ($Current -le 0) {
        return "0 items/sec"
    }

    $seconds = ((Get-Date) - $StartTime).TotalSeconds
    if ($seconds -eq 0) {
        return "Calculating..."
    }

    $speed = $Current / $seconds
    return "{0:N1} items/sec" -f $speed
}

function Show-LoadingBar {
    param(
        [int]$Current,
        [int]$Total,
        [string]$Label = "Cleaning",
        [datetime]$StartTime,
        [string]$CurrentItem = "",
        [string]$CurrentOperation = ""
    )

    if ($Total -le 0) { return }

    $percent = [int](($Current / $Total) * 100)
    $time = Get-TimeStatus -Current $Current -Total $Total -StartTime $StartTime
    $speed = Get-Speed -Current $Current -StartTime $StartTime

    $barLength = 30
    $filled = [math]::Min([math]::Max([int]($percent / 100 * $barLength), 0), $barLength)
    $bar = ('█' * $filled) + ('-' * ($barLength - $filled))

    Write-Host ($Label) -ForegroundColor Cyan
    Write-Host ("Progress: [{0}] {1}%" -f $bar, $percent) -ForegroundColor Green
    Write-Host ("Items: {0} / {1}" -f $Current, $Total) -ForegroundColor Yellow
    Write-Host ("Current: {0}" -f $CurrentItem) -ForegroundColor White
    Write-Host ("Operation: {0}" -f $CurrentOperation) -ForegroundColor White
    Write-Host ("Speed: {0}" -f $speed) -ForegroundColor Magenta
    Write-Host ("Elapsed: {0}" -f $time.Split('|')[0].Trim()) -ForegroundColor Gray
    Write-Host ("ETA: {0}" -f $time.Split('|')[1].Trim()) -ForegroundColor Gray

    if ($Current -eq $Total) {
        Write-Progress -Activity $Label -Completed
    }
    else {
        Write-Progress -Activity $Label -Status "$Current of $Total | $percent%" -PercentComplete $percent
    }
}

function Remove-TargetFileOrFolder {
    param(
        [Parameter(Mandatory = $true)]
        [System.IO.FileSystemInfo]$Item
    )

    try {
        if (Test-IsProtectedPath -Path $Item.FullName) {
            throw "Protected path"
        }

        if (-not (Test-MatchesTarget $Item.Name)) {
            throw "Deletion blocked: unexpected filename"
        }

        if ($Item.PSIsContainer) {
            Remove-Item -LiteralPath $Item.FullName -Recurse -Force -ErrorAction Stop
        }
        else {
            Remove-Item -LiteralPath $Item.FullName -Force -ErrorAction Stop
        }

        if (-not $Item.PSIsContainer -and $Item.PSObject.Properties.Match('Length').Count -gt 0) {
            $script:RecoveredBytes += $Item.Length
        }

        Add-DeletedItem -Kind (if ($Item.PSIsContainer) { "FOLDER" } else { "FILE" }) -Name $Item.Name -Path $Item.FullName -Timestamp $Item.LastAccessTime

        return [pscustomobject]@{
            Success = $true
            Item = $Item
            Reason = $null
        }
    }
    catch {
        Add-FailedItem -Kind (if ($Item.PSIsContainer) { "FOLDER" } else { "FILE" }) -Name $Item.Name -Path $Item.FullName -Reason $_.Exception.Message

        return [pscustomobject]@{
            Success = $false
            Item = $Item
            Reason = $_.Exception.Message
        }
    }
}

function Stop-TargetProcesses {
    foreach ($target in $TargetNames) {
        $processName = [System.IO.Path]::GetFileNameWithoutExtension($target)
        $processes = Get-Process -Name $processName -ErrorAction SilentlyContinue

        if ($processes) {
            Write-Host "Stopping process: $processName" -ForegroundColor Yellow
            Stop-Process -Name $processName -Force -ErrorAction SilentlyContinue
            $script:CleanupSummary.ProcessesStopped += $processes.Count
        }
    }
}

function Remove-EmptyDirectories {
    param([string[]]$Paths)

    $removed = 0

    foreach ($path in $Paths) {
        if (-not (Test-Path -LiteralPath $path)) { continue }

        $dirs = Get-ChildItem -LiteralPath $path -Directory -Recurse -Force -ErrorAction SilentlyContinue |
            Sort-Object FullName -Descending

        foreach ($dir in $dirs) {
            if (-not (Test-IsProtectedPath -Path $dir.FullName)) {
                $childItems = @(Get-ChildItem -LiteralPath $dir.FullName -Force -ErrorAction SilentlyContinue)
                if ($childItems.Count -eq 0) {
                    Remove-Item -LiteralPath $dir.FullName -Force -ErrorAction SilentlyContinue
                    $removed++
                }
            }
        }
    }

    return $removed
}

function Get-LeafName {
    param([string]$Text)

    if ([string]::IsNullOrWhiteSpace($Text)) {
        return $null
    }

    $trimmed = $Text.Trim().Trim('"')
    if ([string]::IsNullOrWhiteSpace($trimmed)) {
        return $null
    }

    try {
        $leaf = [System.IO.Path]::GetFileName($trimmed)
        if ([string]::IsNullOrWhiteSpace($leaf)) {
            return $trimmed
        }
        return $leaf
    }
    catch {
        return $trimmed
    }
}

function Test-TargetReference {
    param([string]$Text)

    $leaf = Get-LeafName -Text $Text
    if ([string]::IsNullOrWhiteSpace($leaf)) {
        return $false
    }

    return $TargetNames.Contains($leaf)
}

function Convert-ToRot13 {
    param([string]$Text)

    if ([string]::IsNullOrWhiteSpace($Text)) {
        return $Text
    }

    $chars = $Text.ToCharArray()
    for ($i = 0; $i -lt $chars.Length; $i++) {
        $char = $chars[$i]
        if ($char -ge 'a' -and $char -le 'z') {
            $chars[$i] = [char]((([int]$char - [int][char]'a' + 13) % 26) + [int][char]'a')
        }
        elseif ($char -ge 'A' -and $char -le 'Z') {
            $chars[$i] = [char]((([int]$char - [int][char]'A' + 13) % 26) + [int][char]'A')
        }
    }

    return -join $chars
}

function Get-ShortcutTarget {
    param([string]$Path)

    if (-not (Test-Path -LiteralPath $Path)) {
        return $null
    }

    try {
        $shell = New-Object -ComObject WScript.Shell
        $shortcut = $shell.CreateShortcut($Path)
        return $shortcut.TargetPath
    }
    catch {
        return $null
    }
}

function Remove-ShortcutArtifacts {
    param([string[]]$Paths)

    $removed = 0

    foreach ($path in $Paths) {
        if (-not (Test-Path -LiteralPath $path)) { continue }

        $shortcuts = Get-ChildItem -LiteralPath $path -Recurse -File -ErrorAction SilentlyContinue |
            Where-Object { $_.Extension -in @('.lnk', '.url') }

        foreach ($shortcut in $shortcuts) {
            try {
                $target = Get-ShortcutTarget -Path $shortcut.FullName
                if (Test-TargetReference -Text $target) {
                    Remove-Item -LiteralPath $shortcut.FullName -Force -ErrorAction Stop
                    Add-DeletedItem -Kind "SHORTCUT" -Name $shortcut.Name -Path $shortcut.FullName -Timestamp $shortcut.LastWriteTime
                    $script:CleanupSummary.ShortcutsRemoved++
                    $removed++
                }
            }
            catch {
                Add-FailedItem -Kind "SHORTCUT" -Name $shortcut.Name -Path $shortcut.FullName -Reason $_.Exception.Message
            }
        }
    }

    return $removed
}

function Remove-FirewallArtifacts {
    $removed = 0

    if (-not (Get-Command Get-NetFirewallRule -ErrorAction SilentlyContinue)) {
        return $removed
    }

    foreach ($rule in Get-NetFirewallRule -ErrorAction SilentlyContinue) {
        try {
            $filters = @(Get-NetFirewallApplicationFilter -AssociatedNetFirewallRule $rule -ErrorAction SilentlyContinue)
            foreach ($filter in $filters) {
                if (Test-TargetReference -Text $filter.Program) {
                    Remove-NetFirewallRule -Name $rule.Name -ErrorAction Stop
                    Add-DeletedItem -Kind "FIREWALL" -Name $rule.DisplayName -Path $rule.Name -Timestamp (Get-Date)
                    $script:CleanupSummary.FirewallRulesRemoved++
                    $removed++
                    break
                }
            }
        }
        catch {
            Add-FailedItem -Kind "FIREWALL" -Name $rule.DisplayName -Path $rule.Name -Reason $_.Exception.Message
        }
    }

    return $removed
}

function Remove-DefenderExclusions {
    if (-not (Get-Command Get-MpPreference -ErrorAction SilentlyContinue)) {
        return 0
    }

    $removed = 0

    try {
        $prefs = Get-MpPreference -ErrorAction Stop
        foreach ($path in @($prefs.ExclusionPath)) {
            if ([string]::IsNullOrWhiteSpace($path)) { continue }
            if (Test-TargetReference -Text $path) {
                Remove-MpPreference -ExclusionPath $path -ErrorAction SilentlyContinue
                Add-DeletedItem -Kind "DEFENDER" -Name ([System.IO.Path]::GetFileName($path)) -Path $path -Timestamp (Get-Date)
                $removed++
            }
        }
    }
    catch {
    }

    return $removed
}

function Remove-RegistryArtifactValues {
    param(
        [Parameter(Mandatory)]
        [string]$Path,
        [switch]$InspectData,
        [switch]$InspectName,
        [switch]$DecodeName
    )

    $removed = 0

    if (-not (Test-Path -LiteralPath $Path)) {
        return $removed
    }

    $keys = @(Get-ChildItem -LiteralPath $Path -Recurse -ErrorAction SilentlyContinue)
    foreach ($key in $keys) {
        foreach ($valueName in @($key.GetValueNames())) {
            $valueData = $null
            try {
                $valueData = $key.GetValue($valueName)
            }
            catch {
            }

            $match = $false
            $candidateText = $null

            if ($InspectName) {
                $candidateText = $valueName
                if ($DecodeName) {
                    $candidateText = Convert-ToRot13 -Text $candidateText
                }
                if (Test-TargetReference -Text $candidateText) {
                    $match = $true
                }
            }

            if (-not $match -and $InspectData -and $null -ne $valueData) {
                $candidateText = [string]$valueData
                if (Test-TargetReference -Text $candidateText) {
                    $match = $true
                }
            }

            if ($match) {
                try {
                    Remove-ItemProperty -Path $key.PSPath -Name $valueName -ErrorAction Stop
                    Add-DeletedItem -Kind "REGISTRY" -Name $valueName -Path $key.PSPath -Timestamp ([datetime]::MinValue)
                    $script:CleanupSummary.RegistryArtifactsRemoved++
                    if ($Path -match 'RecentDocs|RunMRU') {
                        $script:CleanupSummary.RecentItemsRemoved++
                    }
                    elseif ($Path -match 'UserAssist') {
                        $script:CleanupSummary.UserAssistEntriesRemoved++
                    }
                    $removed++
                }
                catch {
                    Add-FailedItem -Kind "REGISTRY" -Name $valueName -Path $key.PSPath -Reason $_.Exception.Message
                }
            }
        }
    }

    return $removed
}

