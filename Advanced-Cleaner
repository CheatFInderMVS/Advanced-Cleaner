)
foreach ($path in $startupPaths) {
    if (Test-Path -LiteralPath $path) {
        $props = Get-ItemProperty -Path $path -ErrorAction SilentlyContinue
        foreach ($propName in $props.PSObject.Properties.Name) {
            if ($propName -in @('PSPath', 'PSParentPath', 'PSChildName', 'PSDrive', 'PSProvider')) { continue }

            $value = $props.$propName
            $matchesName = Test-MatchesTarget $propName
            $matchesValue = $false

            if ($value -is [string]) {
                $matchesValue = Test-TargetReference -Text $value
            }

            if ($matchesName -or $matchesValue) {
                Remove-ItemProperty -Path $path -Name $propName -ErrorAction SilentlyContinue
                $script:CleanupSummary.StartupEntriesRemoved++
            }
        }
    }
}

if (Get-Command Get-ScheduledTask -ErrorAction SilentlyContinue) {
    $tasks = Get-ScheduledTask -ErrorAction SilentlyContinue
    foreach ($task in $tasks) {
        foreach ($action in @($task.Actions)) {
            $leaf = [System.IO.Path]::GetFileName($action.Execute)
            if (Test-MatchesTarget $leaf) {
                Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false -ErrorAction SilentlyContinue
                $script:CleanupSummary.ScheduledTasksRemoved++
                break
            }
        }
    }
}

$services = Get-CimInstance Win32_Service -ErrorAction SilentlyContinue
foreach ($service in $services) {
    $servicePath = [string]$service.PathName
    $binaryName = $null

    if ($servicePath -match '(?i)([a-z]:\\.+?\.exe)') {
        $binaryName = Split-Path $Matches[1] -Leaf
    }
    else {
        $binaryName = [System.IO.Path]::GetFileName($servicePath)
    }

    if (Test-MatchesTarget $binaryName) {
        Stop-Service -Name $service.Name -ErrorAction SilentlyContinue
        Invoke-CimMethod -ClassName Win32_Service -MethodName Delete -Arguments @{ Name = $service.Name } -ErrorAction SilentlyContinue | Out-Null
        $script:CleanupSummary.ServicesRemoved++
    }
}

Write-Host ""
Write-Host "[8/8] CLEANING WINDOWS ARTIFACTS" -ForegroundColor Cyan
Write-Host "Removing shortcut, firewall, and registry artifact references..." -ForegroundColor White
Write-Host ""

Remove-ShortcutArtifacts -Paths @(
    "$env:APPDATA\Microsoft\Windows\Start Menu\Programs",
    "$env:USERPROFILE\Desktop",
    "$env:APPDATA\Microsoft\Windows\Recent"
) | Out-Null

Remove-FirewallArtifacts | Out-Null
Remove-DefenderExclusions | Out-Null

Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RecentDocs" -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RunMRU" -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\MuiCache" -InspectName -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Compatibility Assistant\Store" -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers" -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers" -InspectData | Out-Null
Remove-RegistryArtifactValues -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\UserAssist" -InspectName -InspectData -DecodeName | Out-Null

# REPORTING
$RecoveredMB = [math]::Round($RecoveredBytes / 1MB, 2)
$RecoveredGB = [math]::Round($RecoveredBytes / 1GB, 2)
$filesDeleted = ($DeletedItems | Where-Object { $_.Kind -eq "FILE" }).Count
$foldersDeleted = ($DeletedItems | Where-Object { $_.Kind -eq "FOLDER" }).Count
$registryDeleted = ($DeletedItems | Where-Object { $_.Kind -eq "REGISTRY" }).Count
$totalRemoved = $filesDeleted + $foldersDeleted + $registryDeleted

if ($DeletedItems.Count -eq 0 -and $FailedItems.Count -eq 0) {
    Write-Host ""
    Write-Host "================================================" -ForegroundColor Cyan
    Write-Host "              SYSTEM CLEAN" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "No matching targets were found." -ForegroundColor Yellow
    Write-Host "No changes were made." -ForegroundColor Yellow
    Write-Host "================================================" -ForegroundColor Cyan
    exit
}

Write-Host ""
Write-Host "================================================" -ForegroundColor Cyan
Write-Host "                 CLEANUP COMPLETE" -ForegroundColor Cyan
Write-Host "================================================" -ForegroundColor Cyan
Write-Host ""
Write-Host "Results:" -ForegroundColor Yellow
Write-Host ("Files deleted: {0}" -f $filesDeleted) -ForegroundColor White
Write-Host ("Folders deleted: {0}" -f $foldersDeleted) -ForegroundColor White
Write-Host ("Registry items deleted: {0}" -f $registryDeleted) -ForegroundColor White
Write-Host ("Temporary files deleted: {0}" -f $CleanupSummary.TemporaryFilesDeleted) -ForegroundColor White
Write-Host ("Empty folders removed: {0}" -f $CleanupSummary.EmptyFoldersRemoved) -ForegroundColor White
Write-Host ("Startup entries removed: {0}" -f $CleanupSummary.StartupEntriesRemoved) -ForegroundColor White
Write-Host ("Scheduled tasks removed: {0}" -f $CleanupSummary.ScheduledTasksRemoved) -ForegroundColor White
Write-Host ("Services removed: {0}" -f $CleanupSummary.ServicesRemoved) -ForegroundColor White
Write-Host ("Firewall rules removed: {0}" -f $CleanupSummary.FirewallRulesRemoved) -ForegroundColor White
Write-Host ("Shortcuts removed: {0}" -f $CleanupSummary.ShortcutsRemoved) -ForegroundColor White
Write-Host ("Registry artifacts removed: {0}" -f $CleanupSummary.RegistryArtifactsRemoved) -ForegroundColor White
Write-Host ("Total removed: {0}" -f $totalRemoved) -ForegroundColor White
Write-Host ("Space recovered: {0} GB ({1} MB)" -f $RecoveredGB, $RecoveredMB) -ForegroundColor Green
Write-Host ("Finished: {0}" -f (Get-Date)) -ForegroundColor Gray
Write-Host ""

if ($FailedItems.Count -gt 0) {
    Write-Host "Failed removals:" -ForegroundColor Red
    foreach ($failure in $FailedItems) {
        Write-Host ("- {0}" -f $failure.Name) -ForegroundColor Red
        Write-Host ("  Reason: {0}" -f $failure.Reason) -ForegroundColor DarkRed
    }
    Write-Host ""
}

Write-Host "Deleted items preview:" -ForegroundColor Cyan
foreach ($entry in $DeletedItems) {
    Write-Host ""
    Write-Host ("- TYPE = {0}" -f $entry.Kind) -ForegroundColor White
    Write-Host ("- NAME = {0}" -f $entry.Name) -ForegroundColor White
    Write-Host ("- PATH = {0}" -f $entry.Path) -ForegroundColor White

    $timestampValue = if ($entry.PSObject.Properties.Match('Timestamp').Count -gt 0) { $entry.Timestamp } else { $entry.LastAccessTime }
    Write-Host ("- TIMESTAMP = {0}" -f $timestampValue) -ForegroundColor White

    if ($entry.PSObject.Properties.Match('Reason').Count -gt 0 -and $null -ne $entry.Reason) {
        Write-Host ("- REASON = {0}" -f $entry.Reason) -ForegroundColor DarkGray
    }
}
Write-Host ""
Write-Host "================================================" -ForegroundColor Cyan
